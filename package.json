{
    "name": "App",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "serve": "set NODE_OPTIONS=--openssl-legacy-provider &&  vue-cli-service serve",
        "build": "vue-cli-service build",
        "build-mobithree": "vue-cli-service build --mode mobithree",
        "build-test": "vue-cli-service build --mode test",
        "test": "vue-cli-service serve --mode test",
        "lint": "vue-cli-service lint",
        "pkg": "vue-cli-service build && vue-cli-service build --mode mobithree"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^1.2.32",
        "@fortawesome/free-solid-svg-icons": "^5.15.1",
        "@fortawesome/vue-fontawesome": "^2.0.0",
        "@syncfusion/ej2-vue-schedule": "^18.2.54",
        "@tinymce/tinymce-vue": "^3.2.8",
        "autoprefixer": "^9.7.2",
        "axios": "^0.19.0",
        "bootstrap": "^4.3.1",
        "bootstrap-vue": "^2.15.0",
        "core-js": "^2.6.10",
        "filepond": "^4.4.11",
        "jquery": "^3.4.1",
        "luxon": "^1.25.0",
        "moment": "^2.29.4",
        "popper.js": "^1.16.0",
        "ryuu.js": "^3.0.2",
        "vue": "^2.6.10",
        "vue-multiselect": "^2.1.6",
        "vue-router": "^3.0.3",
        "vue-sidebar-menu": "^4.7.4",
        "vuex": "^3.1.1",
        "webpack": "^4.41.2"
    },
    "devDependencies": {
        "@vue/cli-plugin-babel": "^3.11.0",
        "@vue/cli-plugin-eslint": "^3.11.0",
        "@vue/cli-service": "^3.11.0",
        "babel-eslint": "^10.0.1",
        "eslint": "^5.16.0",
        "eslint-plugin-vue": "^5.0.0",
        "sass": "^1.23.0",
        "sass-loader": "^8.0.0",
        "vue-template-compiler": "^2.6.10",
        "xml-webpack-plugin": "^1.0.1"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended"
        ],
        "globals": {
            "Utils": true,
            "TMPDATA": true,
            "$": true
        },
        "rules": {
            "no-console": 0,
            "no-debugger": 0,
            "no-useless-escape": 0
        },
        "parserOptions": {
            "parser": "babel-eslint"
        }
    },
    "postcss": {
        "plugins": {
            "autoprefixer": {}
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ]
}
